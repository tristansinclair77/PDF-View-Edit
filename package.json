{
  "name": "pdf-view-edit",
  "version": "1.0.0",
  "description": "Desktop PDF viewer and editor",
  "main": "dist/main/index.mjs",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "unset ELECTRON_RUN_AS_NODE && electron-vite build",
    "build:electron": "unset ELECTRON_RUN_AS_NODE && electron-vite build && electron-builder",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pdf",
    "editor",
    "viewer",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "fabric": "^7.2.0",
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
